# Database
DATABASE_URL=postgresql://user:password@localhost:5432/doorstax

# Auth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Kadima Gateway (Sandbox)
KADIMA_API_BASE=https://sandbox-gateway.kadimadashboard.com/api
KADIMA_API_TOKEN=your-kadima-api-token
KADIMA_GATEWAY_TOKEN=your-kadima-gateway-token
KADIMA_TERMINAL_ID=your-terminal-id
KADIMA_ACH_TERMINAL_LOW=terminal-id-for-under-200
KADIMA_ACH_TERMINAL_HIGH=terminal-id-for-200-and-above
KADIMA_DBA_ID=your-dba-id
KADIMA_WEBHOOK_SECRET=your-webhook-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# VPN / Geolocation Check (vpnapi.io — free tier: 1,000 req/day)
VPNAPI_KEY=your-vpnapi-key

# Upstash Redis (Rate Limiting + Caching)
# Get free tier at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron Secret (Vercel Cron auth)
CRON_SECRET=generate-a-random-secret-here

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps / Places (address autocomplete in the property wizard,
# property edit, and any future address-bearing forms).
#
# Required APIs to enable in Google Cloud Console (one project):
#   - Maps JavaScript API
#   - Places API           (legacy — works for keys created before 2025-03-01)
#   - Places API (New)     (required for keys created on/after 2025-03-01)
#
# Suggested key restrictions (Cloud Console → Credentials → the key):
#   - Application restrictions: HTTP referrers
#       https://app.doorstax.com/*
#       https://*.doorstax.com/*
#       http://localhost:3000/*
#       http://localhost:*    (if you use random preview ports)
#   - API restrictions: Maps JavaScript API + Places API + Places API (New)
#
# This var is exposed to the browser by design (Next.js NEXT_PUBLIC_*).
# Restrict the key by referrer + API in Cloud Console — that's the
# real security boundary.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key
