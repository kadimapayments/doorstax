generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PM
  TENANT
  ADMIN
  OWNER
  PARTNER
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  RENT
  DEPOSIT
  FEE
  APPLICATION
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum BoardingStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  MAINTENANCE
  PLUMBING
  ELECTRICAL
  HVAC
  PEST_CONTROL
  GENERAL
  OTHER
}

enum TeamRole {
  MANAGER
  ACCOUNTING
  CARETAKER
  SERVICE_TECH
}

enum AdminRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  OPERATIONS_MANAGER
  FINANCE_MANAGER
  SUPPORT_AGENT
  VIEWER
}

enum PropertyType {
  SINGLE_FAMILY
  MULTIFAMILY
  OFFICE
  COMMERCIAL
}

enum LeaseStatus {
  PENDING
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum AddendumType {
  RENEWAL
  TERMINATION
  AMENDMENT
}

enum ExpenseCategory {
  SERVICES
  UPGRADES
  TAXES
  MORTGAGE
  INSURANCE
  MAINTENANCE
  PAYROLL
  PROCESSING_FEES
  OTHER
}

enum MessageType {
  DIRECT
  ANNOUNCEMENT
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  APPLIED
  UNDERWRITING
  ONBOARDING
  CONVERTED
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  AGENT
  MANUAL
}

enum ManagerStatus {
  PROSPECT
  ACTIVE
  INACTIVE
}

enum LedgerEntryType {
  CHARGE      // Monthly rent charge
  PAYMENT     // Tenant payment received
  REVERSAL    // Payment refund/return
  ADJUSTMENT  // Manual correction by PM/admin
}

enum PayoutStatus {
  DRAFT
  APPROVED
  PROCESSING
  PAID
  FAILED
}

enum OnboardingStep {
  PERSONAL_DETAILS
  PAYMENT_METHOD
  ROOMMATES
  MOVE_IN_CHECKLIST
  DOCUMENTS
  LEASE_ACKNOWLEDGMENT
  COMPLETE
}

// ─── Users ───────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role
  phone             String?
  twoFactorEnabled  Boolean  @default(false)
  twoFactorPhone    String?
  twoFactorCode     String?
  twoFactorCodeExp  DateTime?
  companyLogo  String?
  companyName  String?
  managerStatus ManagerStatus @default(PROSPECT)
  kadimaCustomerId    String?   // PM vault customer ID
  kadimaBillingId     String?   // PM vault billing info ID
  kadimaCardTokenId   String?   // PM vault card token
  pmCardBrand         String?   // "visa", "mastercard", etc.
  pmCardLast4         String?   // last 4 digits
  kadimaMerchantApiKey    String?   // Per-merchant API key (set by admin after approval)
  kadimaMerchantWebhookSecret String? // Per-merchant webhook secret
  kadimaMerchantTerminalId    String?   // Per-merchant terminal ID
  tosAcceptedAt       DateTime?
  privacyAcceptedAt   DateTime?
  // Compliance timer (Feature 2)
  firstDashboardAccess DateTime?
  complianceDeadline   DateTime?
  suspendedAt          DateTime?
  // Guided Launch Mode (onboarding milestones)
  onboardingMerchantStarted Boolean   @default(false)
  onboardingPropertyAdded   Boolean   @default(false)
  onboardingTenantAdded     Boolean   @default(false)
  onboardingInviteSent      Boolean   @default(false)
  onboardingComplete        Boolean   @default(false)
  onboardingCompletedAt     DateTime?
  // Temp password reset (Feature 7)
  tempPasswordHash     String?
  mustChangePassword   Boolean  @default(false)
  createdAt    DateTime @default(now())

  properties            Property[]
  tenantProfile         TenantProfile?
  tenantInvites         TenantInvite[]
  payments              Payment[] // denormalized landlordId relation
  merchantApplication   MerchantApplication?
  applicationTemplates  ApplicationTemplate[]
  landlordTickets       ServiceTicket[]  @relation("landlordTickets")
  ticketComments        TicketComment[]
  teamOwned             TeamMember[]     @relation("teamOwner")
  teamMemberships       TeamMember[]     @relation("teamMember")
  scheduledPayments     ScheduledPayment[] @relation("scheduledPayments")
  sentMessages          Message[]          @relation("MessageSender")
  messageReceipts       MessageRecipient[]
  landlordLeases        Lease[]            @relation("LandlordLeases")
  landlordExpenses      Expense[]          @relation("LandlordExpenses")
  subscription          Subscription?
  adminStaffProfile     AdminStaff?
  noticesReceived       DashboardNotice[] @relation("notices_received")
  noticesCreated        DashboardNotice[] @relation("notices_created")
  owners                Owner[]
  feeSchedules          FeeSchedule[]
  screenings            TenantScreening[] @relation("landlordScreenings")
  vendors               Vendor[]
  integrations          Integration[]
  inspections           Inspection[]       @relation("InspectorInspections")
  ownerProfile          Owner?             @relation("OwnerUser")
  // White Label
  whiteLabelPartnerId   String?
  whiteLabelPartner     WhiteLabelPartner? @relation(fields: [whiteLabelPartnerId], references: [id])
  // Agent / Sub-PM
  agentRelationsAsParent AgentRelationship[] @relation("ParentPM")
  agentRelationAsAgent   AgentRelationship?  @relation("AgentUser")
  agentInvites           AgentInvite[]       @relation("AgentInviter")
  propertyStacks         PropertyStack[]
  documentSettings       DocumentSettings?     @relation("DocumentSettings")
  roommateRequestsAsLandlord RoommateRequest[] @relation("RoommateRequestLandlord")
  roommateRequestsProcessed RoommateRequest[]  @relation("RoommateRequestProcessor")
  passwordResetTokens    PasswordResetToken[]
  moveInTemplates        MoveInTemplate[]     @relation("MoveInTemplateLandlord")
  calendarTokens         CalendarToken[]
  assignedLeads          Lead[]           @relation("LeadAssignee")
  leadActivities         LeadActivity[]   @relation("LeadActivityUser")
  // Architecture improvements
  impersonationSessionsAsAdmin  ImpersonationSession[] @relation("ImpersonationAdmin")
  impersonationSessionsAsTarget ImpersonationSession[] @relation("ImpersonationTarget")
  apiKeys                       ApiKey[]
}

// ─── Calendar Token (iCal feed auth) ────────────

model CalendarToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  token     String    @unique
  label     String    @default("Default")
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([token])
  @@index([userId])
}

// ─── Admin Staff ─────────────────────────────────

model AdminStaff {
  id                String     @id @default(cuid())
  userId            String     @unique
  user              User       @relation(fields: [userId], references: [id])
  adminRole         AdminRole
  customPermissions String[]
  isActive          Boolean    @default(true)
  invitedById       String?
  invitedAt         DateTime   @default(now())
  deactivatedAt     DateTime?

  @@index([adminRole])
}

// ─── Properties & Units ──────────────────────────

// ─── Property Stacks ────────────────────────────

model PropertyStack {
  id          String     @id @default(cuid())
  landlordId  String
  landlord    User       @relation(fields: [landlordId], references: [id])
  name        String     @default("")
  sortOrder   Int        @default(0)
  properties  Property[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([landlordId])
}

model Property {
  id          String   @id @default(cuid())
  landlordId  String
  landlord    User     @relation(fields: [landlordId], references: [id])
  name        String
  address     String
  city        String
  state       String
  zip         String
  propertyType      PropertyType @default(MULTIFAMILY)
  description       String?
  photos            String[]
  kadimaTerminalId  String?
  ownerId           String?
  owner             Owner?   @relation(fields: [ownerId], references: [id])
  stackId           String?
  stack             PropertyStack? @relation(fields: [stackId], references: [id])
  createdAt         DateTime @default(now())

  archivedAt        DateTime?
  purchasePrice   Decimal?  @db.Decimal(12, 2)
  purchaseDate    DateTime?

  units          Unit[]
  messages       Message[]
  leases         Lease[]
  expenses       Expense[]
  inspections    Inspection[]
  welcomePackets WelcomePacket[]

  @@index([landlordId])
  @@index([ownerId])
  @@index([stackId])
}

model Unit {
  id                  String     @id @default(cuid())
  propertyId          String
  property            Property   @relation(fields: [propertyId], references: [id])
  unitNumber          String
  bedrooms            Int?
  bathrooms           Float?
  sqft                Int?
  rentAmount          Decimal    @db.Decimal(10, 2)
  dueDay              Int        @default(1)
  status              UnitStatus @default(AVAILABLE)
  description         String?
  amenities           String[]
  photos              String[]
  listingEnabled          Boolean              @default(false)
  applicationsEnabled     Boolean              @default(false)
  applicationTemplateId   String?
  applicationTemplate     ApplicationTemplate? @relation(fields: [applicationTemplateId], references: [id])
  createdAt               DateTime             @default(now())
  archivedAt              DateTime?

  tenantProfiles    TenantProfile[]
  payments          Payment[]
  applications      Application[]
  recurringBillings RecurringBilling[]
  tenantInvites     TenantInvite[]
  tickets           ServiceTicket[]
  rentSplit         RentSplit?
  scheduledPayments ScheduledPayment[]
  leases            Lease[]
  expenses          Expense[]
  inspections       Inspection[]
  roommateRequests  RoommateRequest[]
  ledgerEntries     LedgerEntry[]
  moveInChecklists  MoveInChecklist[]

  @@index([propertyId])
}

// ─── Tenant Invitations ──────────────────────────

model TenantInvite {
  id         String    @id @default(cuid())
  landlordId String
  landlord   User      @relation(fields: [landlordId], references: [id])
  unitId     String
  unit       Unit      @relation(fields: [unitId], references: [id])
  name       String?
  email      String
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt     DateTime?
  initialCharges Json?
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([unitId])
}

// ─── Tenant Profiles ─────────────────────────────

model TenantProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id])
  unitId            String?
  unit              Unit?     @relation(fields: [unitId], references: [id])
  leaseStart        DateTime?
  leaseEnd          DateTime?
  kadimaCustomerId  String?
  kadimaBillingId   String?   // Kadima vault billing info ID (required for card operations)
  kadimaCardTokenId String?
  cardBrand         String?
  cardLast4         String?
  kadimaAccountId   String?   // ACH bank account ID in Kadima vault
  bankLast4         String?   // Last 4 of bank account number
  bankAccountType   String?   // "checking" or "savings"
  paymentMethodType String?   // "card" or "ach" — which method tenant prefers
  autopayEnabled    Boolean   @default(false)
  splitPercent      Int       @default(100)
  isPrimary         Boolean   @default(true)
  creditReportingEnrolled  Boolean   @default(false)
  creditReportingEnrolledAt DateTime?
  onboardingComplete    Boolean         @default(false)
  onboardingStep        OnboardingStep  @default(PERSONAL_DETAILS)
  leaseAcknowledgedAt   DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  status            String    @default("ACTIVE") // PROSPECT, ACTIVE, PREVIOUS, DELETED
  deletedAt         DateTime?
  deletionReason    String?   // LEASE_ENDED, EVICTION, NON_PAYMENT, VOLUNTARY_DEPARTURE, POLICY_VIOLATION, OTHER
  deletionNotes     String?
  createdAt         DateTime  @default(now())

  payments          Payment[]
  recurringBilling  RecurringBilling?
  tickets           ServiceTicket[]
  rentSplitItems    RentSplitItem[]
  scheduledPayments ScheduledPayment[]
  leases            Lease[]
  roommateRequests  RoommateRequest[]
  ledgerEntries     LedgerEntry[]
  moveInChecklists  MoveInChecklist[]
  tenantDocuments   TenantDocument[]

  @@index([unitId])
}

// ─── Rent Splitting ─────────────────────────────

model RentSplit {
  id        String          @id @default(cuid())
  unitId    String          @unique
  unit      Unit            @relation(fields: [unitId], references: [id])
  totalRent Decimal         @db.Decimal(10, 2)
  splits    RentSplitItem[]
  agreedAt  DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model RentSplitItem {
  id          String        @id @default(cuid())
  rentSplitId String
  rentSplit   RentSplit     @relation(fields: [rentSplitId], references: [id])
  tenantId    String
  tenant      TenantProfile @relation(fields: [tenantId], references: [id])
  percent     Int
  amount      Decimal       @db.Decimal(10, 2)
  agreedAt    DateTime?

  @@unique([rentSplitId, tenantId])
}

// ─── Payments ────────────────────────────────────

model Payment {
  id                  String        @id @default(cuid())
  tenantId            String
  tenant              TenantProfile @relation(fields: [tenantId], references: [id])
  unitId              String
  unit                Unit          @relation(fields: [unitId], references: [id])
  landlordId          String
  landlord            User          @relation(fields: [landlordId], references: [id])
  amount              Decimal       @db.Decimal(10, 2)
  type                PaymentType   @default(RENT)
  status              PaymentStatus @default(PENDING)
  paymentMethod       String?
  cardBrand           String?       // "visa", "mastercard", "amex", "discover"
  cardLast4           String?       // last 4 digits of card
  achLast4            String?       // last 4 digits of bank account
  kadimaTransactionId String?
  kadimaStatus        String?
  declineReasonCode   String?       // gateway decline reason code
  paidAt              DateTime?
  dueDate             DateTime
  description         String?
  surchargeAmount     Decimal?      @db.Decimal(10, 2)
  landlordFee         Decimal?      @db.Decimal(10, 2)
  achAuthorizedAt     DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  ledgerEntries       LedgerEntry[]

  @@index([landlordId, createdAt])
  @@index([tenantId, createdAt])
  @@index([unitId, dueDate])
}

// ─── Recurring Billing ───────────────────────────

model RecurringBilling {
  id                String        @id @default(cuid())
  tenantId          String        @unique
  tenant            TenantProfile @relation(fields: [tenantId], references: [id])
  unitId            String
  unit              Unit          @relation(fields: [unitId], references: [id])
  kadimaRecurringId String?
  amount            Decimal       @db.Decimal(10, 2)
  dayOfMonth        Int
  status            BillingStatus @default(ACTIVE)
  startDate         DateTime
  endDate           DateTime?
  paymentMethod     String        @default("CARD")  // "CARD" or "ACH"
  lastChargeDate    DateTime?
  nextChargeDate    DateTime?
  failedAttempts    Int           @default(0)
  maxRetries        Int           @default(3)
  lastFailureReason String?
  preChargeNotifiedAt DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ─── Rental Applications ─────────────────────────

model Application {
  id            String            @id @default(cuid())
  unitId        String
  unit          Unit              @relation(fields: [unitId], references: [id])
  name          String
  email         String
  phone         String
  employment    String
  employer      String?
  income        Decimal           @db.Decimal(10, 2)
  rentalHistory String?
  references    Json?
  customData    Json?
  templateId    String?
  status        ApplicationStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  screenings    TenantScreening[]

  @@index([unitId])
}

// ─── Tenant Screening (RentSpree) ───────────────

enum ScreeningStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
  CANCELLED
}

model TenantScreening {
  id              String          @id @default(cuid())
  applicationId   String
  application     Application     @relation(fields: [applicationId], references: [id])
  landlordId      String
  landlord        User            @relation("landlordScreenings", fields: [landlordId], references: [id])

  // RentSpree integration data
  rentspreeId     String?         @unique
  applyLink       String?
  status          ScreeningStatus @default(PENDING)

  // Results summary (no PII — just pass/fail indicators)
  creditScore     Int?
  creditResult    String?         // "PASS" | "REVIEW" | "FAIL"
  criminalResult  String?
  evictionResult  String?

  requestedAt     DateTime        @default(now())
  completedAt     DateTime?

  @@index([applicationId])
  @@index([landlordId])
}

// ─── Merchant Boarding ──────────────────────────

model MerchantApplication {
  id                  String         @id @default(cuid())
  userId              String         @unique
  user                User           @relation(fields: [userId], references: [id])
  status              BoardingStatus @default(NOT_STARTED)
  kadimaAppId         String?
  // Business info
  businessLegalName   String?
  dba                 String?
  businessType        String?
  ein                 String?
  businessAddress     String?
  businessCity        String?
  businessState       String?
  businessZip         String?
  businessPhone       String?
  businessEmail       String?
  websiteUrl          String?
  // Principal info
  principalFirstName  String?
  principalLastName   String?
  principalTitle      String?
  principalDob        DateTime?
  principalSsn        String?
  principalAddress    String?
  principalCity       String?
  principalState      String?
  principalZip        String?
  ownershipPercent    Int?
  // Processing info
  numberOfBuildings   Int?
  numberOfUnits       Int?
  monthlyVolume       Decimal?       @db.Decimal(12, 2)
  averageTransaction  Decimal?       @db.Decimal(10, 2)
  campaignId          String?
  currentStep         Int            @default(1)
  completedAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  principals          MerchantPrincipal[]
}

model MerchantPrincipal {
  id                    String              @id @default(cuid())
  merchantApplicationId String
  merchantApplication   MerchantApplication @relation(fields: [merchantApplicationId], references: [id], onDelete: Cascade)
  firstName             String
  lastName              String
  title                 String?
  dob                   DateTime?
  address               String?
  city                  String?
  state                 String?
  zip                   String?
  ownershipPercent      Int?
  isManager             Boolean             @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([merchantApplicationId])
}

// ─── Application Templates ──────────────────────

model ApplicationTemplate {
  id          String   @id @default(cuid())
  landlordId  String
  landlord    User     @relation(fields: [landlordId], references: [id])
  name        String
  description String?
  fields      Json     // Array of { name, label, type, required, options? }
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units Unit[]

  @@index([landlordId])
}

// ─── Service Tickets ────────────────────────────

model ServiceTicket {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      TenantProfile  @relation(fields: [tenantId], references: [id])
  unitId      String
  unit        Unit           @relation(fields: [unitId], references: [id])
  landlordId  String
  landlord    User           @relation("landlordTickets", fields: [landlordId], references: [id])
  title       String
  description String
  category    TicketCategory @default(GENERAL)
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  assignedTo    String?
  images        String[]
  createdById   String?
  resolvedAt    DateTime?
  // Work order fields
  estimatedCost Decimal?       @db.Decimal(10, 2)
  actualCost    Decimal?       @db.Decimal(10, 2)
  scheduledDate DateTime?
  completedDate DateTime?
  vendorId      String?
  vendor        Vendor?        @relation(fields: [vendorId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  comments TicketComment[]

  @@index([tenantId])
  @@index([landlordId, status])
  @@index([vendorId])
}

model TicketComment {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    ServiceTicket @relation(fields: [ticketId], references: [id])
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  content   String
  images    String[]
  createdAt DateTime      @default(now())
}

// ─── Scheduled Payments ─────────────────────────

model ScheduledPayment {
  id            String        @id @default(cuid())
  landlordId    String
  landlord      User          @relation("scheduledPayments", fields: [landlordId], references: [id])
  tenantId      String
  tenant        TenantProfile @relation(fields: [tenantId], references: [id])
  unitId        String
  unit          Unit          @relation(fields: [unitId], references: [id])
  amount        Decimal       @db.Decimal(10, 2)
  type          PaymentType   @default(RENT)
  description   String?
  scheduledDate DateTime
  executed      Boolean       @default(false)
  executedAt    DateTime?
  paymentId     String?
  createdAt     DateTime      @default(now())

  @@index([landlordId, scheduledDate])
  @@index([executed, scheduledDate])
}

// ─── Team Members ───────────────────────────────

model TeamMember {
  id          String   @id @default(cuid())
  landlordId  String
  landlord    User     @relation("teamOwner", fields: [landlordId], references: [id])
  userId      String
  user        User     @relation("teamMember", fields: [userId], references: [id])
  role        TeamRole
  propertyIds String[]
  isActive    Boolean  @default(true)
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime?

  @@unique([landlordId, userId])
}

// ─── Messages & Announcements ─────────────────────

model Message {
  id          String          @id @default(cuid())
  senderId    String
  sender      User            @relation("MessageSender", fields: [senderId], references: [id])
  propertyId  String?
  property    Property?       @relation(fields: [propertyId], references: [id])
  threadId    String?
  type        MessageType     @default(DIRECT)
  subject     String
  body        String
  priority    MessagePriority @default(NORMAL)
  imageUrl    String?
  recipients  MessageRecipient[]
  createdAt   DateTime        @default(now())

  @@index([senderId, createdAt])
  @@index([threadId])
}

model MessageRecipient {
  id             String    @id @default(cuid())
  messageId      String
  message        Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  readAt         DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

// ─── Leases ────────────────────────────────────

model Lease {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        TenantProfile @relation(fields: [tenantId], references: [id])
  unitId        String
  unit          Unit        @relation(fields: [unitId], references: [id])
  propertyId    String
  property      Property    @relation(fields: [propertyId], references: [id])
  landlordId    String
  landlord      User        @relation("LandlordLeases", fields: [landlordId], references: [id])
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal     @db.Decimal(10, 2)
  status            LeaseStatus @default(ACTIVE)
  documentUrl       String?
  notes             String?
  // E-signature fields
  signedByTenant    Boolean  @default(false)
  signedByLandlord  Boolean  @default(false)
  tenantSignedAt    DateTime?
  landlordSignedAt  DateTime?
  signatureData     String?  // Base64 signature image
  lastAlertDays     Int?     // Tracks last expiration alert threshold sent (90, 60, 30, 14, 7)
  addendums         LeaseAddendum[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([landlordId])
  @@index([tenantId])
  @@index([unitId])
  @@index([status, endDate])
}

model LeaseAddendum {
  id            String       @id @default(cuid())
  leaseId       String
  lease         Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  type          AddendumType
  newRentAmount Decimal?     @db.Decimal(10, 2)
  newEndDate    DateTime?
  notes         String?
  documentUrl   String?
  createdAt     DateTime     @default(now())

  @@index([leaseId])
}

// ─── Expenses ──────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  propertyId  String
  property    Property        @relation(fields: [propertyId], references: [id])
  unitId      String?
  unit        Unit?           @relation(fields: [unitId], references: [id])
  landlordId  String
  landlord    User            @relation("LandlordExpenses", fields: [landlordId], references: [id])
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String
  vendor      String?
  recurring   Boolean         @default(false)
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([landlordId])
  @@index([propertyId, date])
}

// ─── Subscriptions ──────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id])
  status           SubscriptionStatus @default(TRIALING)
  basePrice        Decimal            @db.Decimal(10, 2) @default(150.00)
  perBuildingPrice Decimal            @db.Decimal(10, 2) @default(3.00)
  buildingCount    Int                @default(1)
  currentAmount    Decimal            @db.Decimal(10, 2)
  nextBillingDate  DateTime
  lastBillingDate  DateTime?
  trialEndsAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  payments         SubscriptionPayment[]
}

model SubscriptionPayment {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  amount          Decimal      @db.Decimal(10, 2)
  status          String       @default("COMPLETED")
  billingPeriod   String
  paidAt          DateTime     @default(now())
  createdAt       DateTime     @default(now())
}

// ─── Dashboard Notices (Admin→Landlord, Landlord→Tenant) ───

model DashboardNotice {
  id           String    @id @default(cuid())
  targetUserId String
  targetUser   User      @relation("notices_received", fields: [targetUserId], references: [id])
  createdById  String
  createdBy    User      @relation("notices_created", fields: [createdById], references: [id])
  type         String    // PAYMENT_DUE, MONEY_OWED, CUSTOM
  title        String
  message      String
  amount       Decimal?  @db.Decimal(10, 2)
  severity     String    @default("warning") // info, warning, urgent
  dismissedAt  DateTime?
  readAt       DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([targetUserId])
}

// ─── Property Owners ─────────────────────────────

model Owner {
  id                   String   @id @default(cuid())
  landlordId           String
  landlord             User     @relation(fields: [landlordId], references: [id])
  userId               String?  @unique
  user                 User?    @relation("OwnerUser", fields: [userId], references: [id])
  name                 String
  email                String?
  phone                String?
  // Kadima vault for ACH credit payouts
  kadimaCustomerId     String?
  bankName             String?
  bankAccountLast4     String?
  // Fee configuration
  managementFeePercent    Decimal  @default(0) @db.Decimal(5, 2)
  achRate                 Decimal  @default(6) @db.Decimal(5, 2) // PM's ACH fee charged to tenants
  payoutFeeRate           Decimal  @default(0.0015) @db.Decimal(6, 4) // 0.15% to 0.5%
  unitFeeRate             Decimal  @default(0) @db.Decimal(5, 2) // $0-$3 per unit/month
  deductProcessingFees    Boolean  @default(true)
  deductExpenses          Boolean  @default(true)
  deductPlatformFee       Boolean  @default(false)
  billMe                  Boolean  @default(false) // PM absorbs all platform costs
  billMeIncludeManagement Boolean  @default(true)  // keep mgmt fee when billMe on
  payoutFrequency         String   @default("MONTHLY") // "MONTHLY" or "SEMI_MONTHLY"
  achFeeResponsibility    String   @default("OWNER")   // "OWNER" | "TENANT" | "PM"
  customFees              Json     @default("[]")       // Array of custom fee configs
  feeScheduleId           String?
  feeSchedule             FeeSchedule? @relation(fields: [feeScheduleId], references: [id])
  // Tax information for 1099 generation
  taxId                   String?   // SSN or EIN for 1099 filing
  taxIdType               String?   // "SSN" or "EIN"
  // Merchant terminal IDs — each owner is a terminal under the PM's merchant account
  terminalId              String?   // Card terminal ID (e.g., "7000", "7001")
  achTerminalId           String?   // ACH terminal ID (e.g., "7000", "7001")

  properties Property[]
  payouts    OwnerPayout[]
  documents  OwnerDocument[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([landlordId])
}

// ─── Owner Payouts ──────────────────────────────

model OwnerPayout {
  id              String       @id @default(cuid())
  ownerId         String
  owner           Owner        @relation(fields: [ownerId], references: [id])
  landlordId      String
  periodStart     DateTime
  periodEnd       DateTime
  grossRent       Decimal      @db.Decimal(12, 2)
  processingFees  Decimal      @db.Decimal(10, 2)
  managementFee   Decimal      @db.Decimal(10, 2)
  expenses        Decimal      @db.Decimal(10, 2)
  platformFee     Decimal      @db.Decimal(10, 2)
  netPayout       Decimal      @db.Decimal(12, 2)
  achRate         Decimal?     @db.Decimal(5, 2)   // PM's ACH rate used for this payout
  payoutFee       Decimal      @default(0) @db.Decimal(10, 2) // payout processing fee (deducted from owner)
  payoutFeeRate   Decimal?     @db.Decimal(6, 4)  // snapshot of rate used (e.g. 0.0015 = 0.15%)
  unitFee         Decimal      @default(0) @db.Decimal(10, 2) // per-unit platform fee
  status          PayoutStatus @default(DRAFT)
  paidAt          DateTime?
  paymentMethod   String?      // "ach" | "manual" | "check" | "wire"
  kadimaTransactionId String?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([ownerId, periodStart])
  @@index([landlordId, status])
}

// ─── Fee Schedules ──────────────────────────────

model FeeSchedule {
  id                      String   @id @default(cuid())
  landlordId              String
  landlord                User     @relation(fields: [landlordId], references: [id])
  name                    String
  managementFeePercent    Decimal  @default(0) @db.Decimal(5, 2)
  achRate                 Decimal  @default(6) @db.Decimal(5, 2)
  payoutFeeRate           Decimal  @default(0.0015) @db.Decimal(6, 4) // 0.15% to 0.5%
  unitFeeRate             Decimal  @default(0) @db.Decimal(5, 2) // $0-$3 per unit/month
  deductProcessingFees    Boolean  @default(true)
  deductExpenses          Boolean  @default(true)
  deductPlatformFee       Boolean  @default(false)
  billMe                  Boolean  @default(false)
  billMeIncludeManagement Boolean  @default(true)
  payoutFrequency         String   @default("MONTHLY") // "MONTHLY" or "SEMI_MONTHLY"
  achFeeResponsibility    String   @default("OWNER")   // "OWNER" | "TENANT" | "PM"
  customFees              Json     @default("[]")       // Array of custom fee configs
  owners                  Owner[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([landlordId])
}

// ─── Vendors ──────────────────────────────────

model Vendor {
  id          String   @id @default(cuid())
  landlordId  String
  landlord    User     @relation(fields: [landlordId], references: [id])
  name        String
  email       String?
  phone       String?
  company     String?
  category    String   // PLUMBING, ELECTRICAL, HVAC, GENERAL, ROOFING, etc.
  notes       String?
  rating      Float?
  isActive      Boolean  @default(true)
  // Tax / W-9 information
  taxId         String?
  taxIdType     String?   // "SSN" or "EIN"
  w9Status      String    @default("NOT_REQUESTED") // NOT_REQUESTED, REQUESTED, RECEIVED, VERIFIED
  w9DocumentUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tickets     ServiceTicket[]

  @@index([landlordId])
}

// ─── Owner Documents ────────────────────────────

model OwnerDocument {
  id        String   @id @default(cuid())
  ownerId   String
  owner     Owner    @relation(fields: [ownerId], references: [id])
  name      String
  url       String
  type      String   // STATEMENT, TAX_DOC, AGREEMENT, OTHER
  period    String?  // e.g., "2026-03"
  createdAt DateTime @default(now())

  @@index([ownerId])
}

// ─── Document Settings ─────────────────────────

model DocumentSettings {
  id            String   @id @default(cuid())
  landlordId    String   @unique
  landlord      User     @relation("DocumentSettings", fields: [landlordId], references: [id])
  primaryColor  String   @default("#5B00FF")
  footerText    String?
  logoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([landlordId])
}

// ─── Integrations ───────────────────────────────

model Integration {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  provider     String    // QUICKBOOKS, XERO
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  webhooks IntegrationWebhook[]

  @@index([userId])
}

// ─── Inspections ────────────────────────────────

enum InspectionType {
  MOVE_IN
  MOVE_OUT
  ROUTINE
  INITIAL
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model Inspection {
  id           String           @id @default(cuid())
  propertyId   String
  property     Property         @relation(fields: [propertyId], references: [id])
  unitId       String?
  unit         Unit?            @relation(fields: [unitId], references: [id])
  type         InspectionType
  status       InspectionStatus @default(SCHEDULED)
  scheduledAt  DateTime?
  completedAt  DateTime?
  inspectorId  String?
  inspector    User?            @relation("InspectorInspections", fields: [inspectorId], references: [id])
  notes        String?
  items        InspectionItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([propertyId])
  @@index([inspectorId])
}

model InspectionItem {
  id            String     @id @default(cuid())
  inspectionId  String
  inspection    Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  area          String     // Kitchen, Bathroom, Bedroom, etc.
  item          String     // Walls, Floor, Ceiling, Appliance, etc.
  condition     String     // GOOD, FAIR, POOR, DAMAGED
  photos        String[]
  notes         String?
  repairNeeded  Boolean    @default(false)
  estimatedCost Decimal?   @db.Decimal(10, 2)

  @@index([inspectionId])
}

// ─── White Label Partners ────────────────────────

model WhiteLabelPartner {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  customDomain     String?  @unique
  logoUrl          String?
  faviconUrl       String?
  primaryColor     String   @default("#5B00FF")
  accentColor      String   @default("#BDA2FF")
  platformFeeShare Decimal  @default(0.60) @db.Decimal(4, 2)
  monthlyFee       Decimal  @default(0) @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users User[]
}

// ─── Agent / Sub-PM Relationships ────────────────

model AgentRelationship {
  id               String   @id @default(cuid())
  parentPmId       String
  parentPm         User     @relation("ParentPM", fields: [parentPmId], references: [id])
  agentUserId      String   @unique
  agentUser        User     @relation("AgentUser", fields: [agentUserId], references: [id])
  perUnitCost      Decimal  @db.Decimal(5, 2)
  cardRateOverride Decimal? @db.Decimal(6, 4)
  achRateOverride  Decimal? @db.Decimal(5, 2)
  commissionRate   Decimal  @default(0) @db.Decimal(5, 4)
  residualSplit    Decimal  @default(0) @db.Decimal(5, 4)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([parentPmId])
}

model AgentInvite {
  id               String    @id @default(cuid())
  parentPmId       String
  parentPm         User      @relation("AgentInviter", fields: [parentPmId], references: [id])
  email            String
  tokenHash        String    @unique
  perUnitCost      Decimal   @db.Decimal(5, 2)
  cardRateOverride Decimal?  @db.Decimal(6, 4)
  achRateOverride  Decimal?  @db.Decimal(5, 2)
  commissionRate   Decimal   @default(0) @db.Decimal(5, 4)
  residualSplit    Decimal   @default(0) @db.Decimal(5, 4)
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime  @default(now())
}

// ─── Password Reset Tokens ──────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Audit Logs ─────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  userRole    String?
  action      String   // CREATE, UPDATE, DELETE, APPROVE, PROCESS, REFUND, LOGIN, IMPERSONATE
  objectType  String   // Payment, Payout, Tenant, User, Lease, etc.
  objectId    String?
  description String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([objectType, objectId])
  @@index([action])
  @@index([createdAt])
}

// ─── Immutable Payment Ledger ───────────────────

model LedgerEntry {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       TenantProfile   @relation(fields: [tenantId], references: [id])
  unitId       String
  unit         Unit            @relation(fields: [unitId], references: [id])
  type         LedgerEntryType
  amount       Decimal         @db.Decimal(10, 2) // positive = owed, negative = credit
  balanceAfter Decimal         @db.Decimal(10, 2) // running balance snapshot after this entry
  periodKey    String          // "2026-03" — the billing month this belongs to
  description  String?         // Human-readable: "March 2026 rent", "Payment received", etc.
  paymentId    String?
  payment      Payment?        @relation(fields: [paymentId], references: [id])
  createdById  String?         // User who caused this entry (null for system/cron)
  locked       Boolean         @default(false)
  metadata     Json?           // Extra context (refund reason, adjustment notes, etc.)
  createdAt    DateTime        @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, periodKey])
  @@index([paymentId])
  @@unique([tenantId, periodKey, type, paymentId])
}

// ─── Roommate Requests ──────────────────────────

model RoommateRequest {
  id              String    @id @default(cuid())
  tenantProfileId String
  tenantProfile   TenantProfile @relation(fields: [tenantProfileId], references: [id])
  unitId          String
  unit            Unit      @relation(fields: [unitId], references: [id])
  landlordId      String
  landlord        User      @relation("RoommateRequestLandlord", fields: [landlordId], references: [id])
  name            String
  email           String
  phone           String?
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  note            String?
  processedAt     DateTime?
  processedById   String?
  processedBy     User?     @relation("RoommateRequestProcessor", fields: [processedById], references: [id])
  createdAt       DateTime  @default(now())

  @@index([tenantProfileId])
  @@index([landlordId, status])
}

// ─── Move-In Checklists ─────────────────────────

model MoveInTemplate {
  id          String   @id @default(cuid())
  landlordId  String
  landlord    User     @relation("MoveInTemplateLandlord", fields: [landlordId], references: [id])
  name        String   @default("Default")
  items       Json     // Array of { area, item, condition, notes }
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([landlordId])
}

model MoveInChecklist {
  id              String         @id @default(cuid())
  tenantProfileId String
  tenantProfile   TenantProfile  @relation(fields: [tenantProfileId], references: [id])
  unitId          String
  unit            Unit           @relation(fields: [unitId], references: [id])
  landlordId      String
  items           Json           // Array of { area, item, condition, notes, acknowledged }
  acknowledgedAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([tenantProfileId, unitId])
  @@index([landlordId])
}

// ─── Tenant Documents ───────────────────────────

model TenantDocument {
  id              String         @id @default(cuid())
  tenantProfileId String
  tenantProfile   TenantProfile  @relation(fields: [tenantProfileId], references: [id])
  landlordId      String
  type            String         // ID, RENTERS_INSURANCE, OTHER
  name            String
  url             String
  uploadedAt      DateTime       @default(now())
  verifiedAt      DateTime?
  verifiedById    String?
  notes           String?

  @@index([tenantProfileId])
  @@index([landlordId])
}

// ─── Welcome Packets ────────────────────────────

model WelcomePacket {
  id              String    @id @default(cuid())
  landlordId      String
  propertyId      String?
  property        Property? @relation(fields: [propertyId], references: [id])
  subject         String    @default("Welcome to Your New Home!")
  body            String
  attachmentUrls  String[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([landlordId])
  @@index([propertyId])
}

// ─── Migration Imports ──────────────────────────

model MigrationImport {
  id                String   @id @default(cuid())
  landlordId        String
  platform          String   // BUILDIUM, APPFOLIO, YARDI, RENT_MANAGER, GENERIC
  fileName          String
  totalRows         Int
  propertiesCreated Int      @default(0)
  unitsCreated      Int      @default(0)
  tenantsCreated    Int      @default(0)
  leasesCreated     Int      @default(0)
  errors            Json?
  status            String   @default("COMPLETED") // COMPLETED, PARTIAL, FAILED
  createdAt         DateTime @default(now())

  @@index([landlordId])
}

// ─── Leads CRM ──────────────────────────────────

model Lead {
  id            String      @id @default(cuid())
  name          String
  email         String
  phone         String      // stored as digits only
  company       String
  buildings     Int?
  units         Int?
  source        LeadSource  @default(WEBSITE)
  status        LeadStatus  @default(NEW)
  notes         String?     @db.Text
  customFields  Json?       // extensible key-value data
  assignedToId  String?
  assignedTo    User?       @relation("LeadAssignee", fields: [assignedToId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  activities    LeadActivity[]

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation("LeadActivityUser", fields: [userId], references: [id])
  type      String   // "status_change", "note", "email_sent", "assigned"
  content   String?  @db.Text
  metadata  Json?    // e.g. { oldStatus, newStatus }
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
//  ARCHITECTURE IMPROVEMENTS
// ═══════════════════════════════════════════════════════════════

// ─── Webhook Idempotency Log ─────────────────────────────────

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

model WebhookEvent {
  id          String             @id @default(cuid())
  eventId     String             @unique   // e.g. "txn_123:ach.completed"
  eventType   String                       // e.g. "ach.completed"
  payload     Json                         // raw webhook payload
  status      WebhookEventStatus @default(RECEIVED)
  attempts    Int                @default(0)
  lastError   String?            @db.Text
  processedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── Server-Side Impersonation Sessions ──────────────────────

model ImpersonationSession {
  id           String    @id @default(cuid())
  adminId      String
  admin        User      @relation("ImpersonationAdmin", fields: [adminId], references: [id])
  targetUserId String
  targetUser   User      @relation("ImpersonationTarget", fields: [targetUserId], references: [id])
  targetRole   Role
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([adminId])
  @@index([tokenHash])
}

// ─── Scoped API Keys ─────────────────────────────────────────

model ApiKey {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  name              String                // human-readable label
  keyHash           String    @unique     // bcrypt hash of full key
  prefix            String                // first 12 chars "dsx_live_XXXX" for lookup
  permissions       String[]              // e.g. ["payments:read", "tenants:read"]
  expiresAt         DateTime?
  revokedAt         DateTime?
  lastUsedAt        DateTime?
  rateLimitPerMinute Int      @default(60)
  createdAt         DateTime  @default(now())

  webhooks IntegrationWebhook[]

  @@index([userId])
  @@index([prefix])
}

// ─── Cron Execution Tracking ─────────────────────────────────

enum CronRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model CronRun {
  id        String        @id @default(cuid())
  jobName   String
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  status    CronRunStatus @default(RUNNING)
  summary   Json?
  error     String?       @db.Text

  @@index([jobName, startedAt])
}

// ─── Domain Events (Internal Event System) ──────────────────

enum DomainEventStatus {
  PENDING
  PROCESSED
  FAILED
}

model DomainEvent {
  id            String            @id @default(cuid())
  eventType     String
  aggregateType String
  aggregateId   String
  payload       Json
  status        DomainEventStatus @default(PENDING)
  handlerErrors Json?
  emittedBy     String?
  processedAt   DateTime?
  createdAt     DateTime          @default(now())

  @@index([eventType, status])
  @@index([aggregateType, aggregateId])
  @@index([createdAt])
}

// ─── Job Queue ──────────────────────────────────────────────

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  DEAD
}

model Job {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(QUEUED)
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?   @db.Text
  runAfter    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  result      Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAfter, priority])
  @@index([type, status])
  @@index([createdAt])
}

// ─── Financial Reconciliation ───────────────────────────────

enum ReconciliationAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ReconciliationAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model ReconciliationReport {
  id                String   @id @default(cuid())
  reportDate        DateTime @unique
  totalGatewayTxns  Int      @default(0)
  totalLocalTxns    Int      @default(0)
  matchedCount      Int      @default(0)
  missingLocal      Int      @default(0)
  missingGateway    Int      @default(0)
  amountMismatches  Int      @default(0)
  duplicatesFound   Int      @default(0)
  totalAlerts       Int      @default(0)
  summary           Json?
  createdAt         DateTime @default(now())

  alerts ReconciliationAlert[]

  @@index([createdAt])
}

model ReconciliationAlert {
  id           String                      @id @default(cuid())
  reportId     String
  report       ReconciliationReport        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  alertType    String
  severity     ReconciliationAlertSeverity  @default(WARNING)
  status       ReconciliationAlertStatus    @default(OPEN)
  paymentId    String?
  gatewayTxnId String?
  details      Json
  resolvedAt   DateTime?
  resolvedById String?
  resolvedNote String?
  createdAt    DateTime                    @default(now())

  @@index([reportId])
  @@index([status])
  @@index([alertType])
}

// ─── Integration Webhooks (Outbound) ────────────────────────

model IntegrationWebhook {
  id              String       @id @default(cuid())
  integrationId   String?
  integration     Integration? @relation(fields: [integrationId], references: [id])
  apiKeyId        String?
  apiKey          ApiKey?      @relation(fields: [apiKeyId], references: [id])
  url             String
  secret          String
  eventTypes      String[]
  isActive        Boolean      @default(true)
  failureCount    Int          @default(0)
  lastDeliveredAt DateTime?
  lastFailedAt    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  deliveries IntegrationWebhookDelivery[]

  @@index([isActive])
}

model IntegrationWebhookDelivery {
  id         String             @id @default(cuid())
  webhookId  String
  webhook    IntegrationWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventType  String
  eventId    String
  payload    Json
  statusCode Int?
  responseBody String?          @db.Text
  deliveredAt  DateTime?
  attempts   Int                @default(0)
  nextRetryAt DateTime?
  createdAt  DateTime           @default(now())

  @@index([webhookId, createdAt])
  @@index([nextRetryAt])
}
